# Every VITE_* value is public and will be embedded in the browser bundle.
# Do not add database passwords, service-role keys, AI keys, signer credentials,
# wallet keys, CEX credentials, or webhook secrets to this file.
VITE_HERMES_API_ORIGIN=http://localhost:8000
VITE_PRIVY_APP_ID=replace-with-public-app-id
VITE_RELEASE_VERSION=development
VITE_DEPLOYMENT_MODE=managed
VITE_ENABLE_DEV_AUTH_BOOTSTRAP=false
VITE_ENABLE_OPTIONAL_ANALYTICS=false
VITE_SUPPORT_URL=https://support.hermes.invalid
