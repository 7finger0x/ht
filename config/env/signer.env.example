# The application does not receive a raw wallet private key from this service.
HERMES_ENVIRONMENT=development
HERMES_SIGNER_MODE=mock
HERMES_SIGNER_BIND=127.0.0.1:9100
HERMES_SIGNER_POLICY_PATH=/signer/config/signer-policy.yaml
HERMES_SIGNER_REQUEST_AUTH_KEY_REF=secret://development/hermes/signer-request-auth
HERMES_SIGNER_AUDIT_KEY_REF=secret://development/hermes/signer-audit
HERMES_SIGNER_LIVE_ENABLED=false
HERMES_SIGNER_MAX_CLOCK_SKEW_SECONDS=5
