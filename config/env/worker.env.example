HERMES_ENVIRONMENT=development
HERMES_WORKER_ROLE=analysis
HERMES_LOG_LEVEL=INFO
HERMES_LIVE_TRADING_ENABLED=false
HERMES_DATABASE_URL=postgresql://hermes_worker_login:replace-local-only@localhost:5432/hermes
HERMES_REDIS_URL=redis://localhost:6379/0
HERMES_RISK_POLICY_PATH=/app/config/risk-policy.yaml
HERMES_VENUE_REGISTRY_PATH=/app/config/venues.yaml
HERMES_AI_PROVIDER_KEY_REF=secret://development/hermes/ai-provider
HERMES_MARKET_DATA_KEY_REF=secret://development/hermes/market-data
HERMES_FRED_KEY_REF=secret://development/hermes/fred
HERMES_JOB_MAX_ATTEMPTS=5
HERMES_JOB_DEFAULT_DEADLINE_SECONDS=120
