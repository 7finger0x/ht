# Development example only. Production secrets must be injected at runtime from
# a managed secret store or workload identity and must not be committed.
HERMES_ENVIRONMENT=development
HERMES_DEPLOYMENT_MODE=managed
HERMES_SERVICE_NAME=hermes-api
HERMES_LOG_LEVEL=INFO
HERMES_RELEASE_VERSION=development
HERMES_SOURCE_COMMIT=replace-with-git-sha
HERMES_IMAGE_DIGEST=replace-with-image-digest
HERMES_LIVE_TRADING_ENABLED=false
HERMES_API_BIND=0.0.0.0:8000
HERMES_API_RELOAD=false
HERMES_METRICS_ENABLED=true
# Local collector example. In deployed environments, point this at the OTLP/HTTP collector endpoint.
HERMES_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
HERMES_ALLOWED_ORIGINS=http://localhost:5173

# Use a dedicated NOBYPASSRLS application login. Never use a Supabase service-role
# or table-owner connection for ordinary API requests.
HERMES_DATABASE_URL=postgresql://hermes_app_login:replace-local-only@localhost:5432/hermes
HERMES_REDIS_URL=redis://localhost:6379/0

# Identity verification. Values depend on the configured provider. Verification
# keys and client secrets are server-only.
HERMES_AUTH_PROVIDER=privy
HERMES_AUTH_ISSUER=https://auth.example.hermes
HERMES_AUTH_AUDIENCE=replace-with-app-id
HERMES_AUTH_JWT_ALGORITHM=HS256
HERMES_AUTH_JWT_SECRET=replace-local-only
# For RS*/ES* verification, inject the signer/IdP public key PEM at runtime.
HERMES_AUTH_PUBLIC_KEY_PEM=replace-with-public-key-pem
HERMES_AUTH_PRINCIPAL_CLAIM=principal_id
HERMES_AUTH_TENANT_CLAIM=tenant_id
HERMES_AUTH_ROLES_CLAIM=roles
HERMES_AUTH_SCOPES_CLAIM=scope
HERMES_PRIVY_APP_ID=replace-with-app-id
HERMES_AUTH_CLOCK_SKEW_SECONDS=30
HERMES_ENABLE_DEV_AUTH_BOOTSTRAP=false

# Server-side provider credentials are secret references, not literal keys.
HERMES_AI_PROVIDER_KEY_REF=secret://development/hermes/ai-provider
HERMES_MARKET_DATA_KEY_REF=secret://development/hermes/market-data
HERMES_FRED_KEY_REF=secret://development/hermes/fred

HERMES_RISK_POLICY_PATH=/app/config/risk-policy.yaml
HERMES_VENUE_REGISTRY_PATH=/app/config/venues.yaml
HERMES_AUDIT_ARCHIVE_ENABLED=false
HERMES_RAW_MODEL_DIAGNOSTICS_ENABLED=false
HERMES_RAW_MODEL_DIAGNOSTICS_MAX_HOURS=168
