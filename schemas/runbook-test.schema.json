{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.hermes.invalid/runbook-test.schema.json",
  "title": "Hermes Runbook Contract Test Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tested_on", "method", "cases"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tested_on": {
      "type": "string",
      "format": "date"
    },
    "method": {
      "const": "automated-static-contract"
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "runbook",
          "scenario",
          "required_controls",
          "required_evidence",
          "expected_result"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RB-[A-Z0-9-]+$"
          },
          "runbook": {
            "type": "string",
            "pattern": "^runbooks/[a-z0-9-]+\\.md$"
          },
          "scenario": {
            "type": "string",
            "minLength": 20
          },
          "required_controls": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 3}
          },
          "required_evidence": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 3}
          },
          "expected_result": {
            "const": "STATIC_CONTRACT_PASS"
          }
        }
      }
    }
  }
}
